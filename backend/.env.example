# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/quickblog

# Admin credentials (single admin CMS)
ADMIN_EMAIL=admin@example.com

# Option A: plain password (dev only — use hash for production)
ADMIN_PASSWORD=your-secure-password

# Option B: bcrypt hash (recommended for production)
# Generate with: node scripts/hash-password.js your-password
# ADMIN_PASSWORD_HASH=$2b$10$...

# JWT
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=7d

# Google Gemini (AI content generation)
GEMINI_API_KEY=your-gemini-api-key

# ImageKit (image CDN)
IMAGEKIT_PUBLIC_KEY=your-public-key
IMAGEKIT_PRIVATE_KEY=your-private-key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-id

# CORS — set to your deployed frontend URL in production
FRONTEND_URL=http://localhost:5173

# Server
PORT=3000

# Set to 1 when deploying on Vercel (disables local listen)
# VERCEL=1
